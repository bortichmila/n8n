# Основные настройки n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=replace_with_random_string

# База данных
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI (если используете облако)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama (если используете локальную LLM)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Прочие интеграции (CRM и т.д.)
CRM_API_URL=
CRM_API_KEY=
